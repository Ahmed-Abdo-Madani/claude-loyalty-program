# Production database (read-only access recommended, pg_dump uses this)
PRODUCTION_DATABASE_URL=postgresql://user:pass@prod-host:5432/loyalty_prod

# Test database (will be DROP/CREATED, ensure it is SAFE to destroy)
TEST_DATABASE_URL=postgresql://user:pass@localhost:5432/loyalty_test

# PostgreSQL client tools paths (optional, usually auto-detected in PATH)
# PG_DUMP_PATH=/usr/bin/pg_dump
# PG_RESTORE_PATH=/usr/bin/pg_restore
# PSQL_PATH=/usr/bin/psql

# Test server configuration for endpoint testing
# Ensure your local server is running on this port and connected to TEST_DATABASE_URL
TEST_SERVER_PORT=3002
TEST_SERVER_BASE_URL=http://localhost:3002

# Optional: Set to true to keep temp dumps for debugging
# KEEP_TEMP_FILES=true
