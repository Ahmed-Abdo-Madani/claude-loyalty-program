WALLET_NOTIFICATION_DAILY_LIMIT=10
# Maximum wallet notifications per customer per day
# Prevents notification spam

# ----------------------------------------
# Schema Validation (Advanced)
# ----------------------------------------
# SKIP_SCHEMA_VALIDATION=false
# Set to 'true' to skip startup schema checks (emergency bypass only)
# Not recommended for production

# SKIP_SCHEMA_CHECKS=false
# Alternative name for SKIP_SCHEMA_VALIDATION

# ----------------------------------------
# Automatic Migration Configuration
# ----------------------------------------
AUTO_MIGRATE=true
# Set to 'false' to disable automatic migrations on startup
# Default: true in production, recommended to keep enabled
# When enabled, pending migrations run automatically before server starts
# When disabled, migrations must be run manually before deployment

MIGRATION_LOCK_TIMEOUT=30000
# Milliseconds to wait for migration advisory lock
# Default: 30000 (30 seconds)
# Increase if migrations take longer or deployments are slow

MIGRATION_STOP_ON_ERROR=true
# Stop migration execution on first error
# Default: true (recommended for production)
# Set to 'false' to continue running migrations even if one fails (not recommended)

# ========================================
# AUTOMATIC MIGRATION SYSTEM
# ========================================
# The platform now includes automatic migration tracking and execution.
# Migrations run automatically in two places:
#
# 1. Render preDeploy Command (Primary)
#    - Runs: node scripts/deploy-migrations.js
#    - When: After build, before traffic switches to new version
#    - Benefit: Zero-downtime deployments
#    - Requires: Render Starter plan or higher
#
# 2. Server Startup (Safety Net)
#    - Runs: AutoMigrationRunner.runPendingMigrations()
#    - When: During server initialization
#    - Benefit: Catches missed migrations, validates schema
#    - Controlled by: AUTO_MIGRATE environment variable
#
# Migration Tracking:
#    - Table: schema_migrations
#    - Tracks: Applied migrations, execution time, status, checksums
#    - Prevents: Duplicate execution, concurrent runs (advisory locks)
#
# Manual Migration (Emergency):
#    - Disable auto-migrations: AUTO_MIGRATE=false
#    - Run manually: npm run migrate:auto
#    - Check status: npm run migrate:status
#    - List pending: npm run migrate:pending
# ========================================

# ========================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ========================================
# Before deploying to production:
# ✅ Generate strong JWT_SECRET (min 32 chars)
# ✅ Generate strong SESSION_SECRET (min 64 chars)
# ✅ Generate strong ENCRYPTION_KEY (32 chars)
# ✅ Generate strong QR_JWT_SECRET (min 64 chars)
# ✅ Set NODE_ENV=production
# ✅ Set APNS_PRODUCTION=true
# ✅ Upload Apple certificates as base64 env vars
# ✅ Upload Google service account JSON as secret file
# ✅ Set MOYASAR_SECRET_KEY and MOYASAR_PUBLISHABLE_KEY (production keys)
# ✅ Verify MOYASAR_PUBLISHABLE_KEY starts with pk_live_ (not pk_test_)
# ✅ Configure MOYASAR_CALLBACK_URL with production domain
# ✅ Configure all 12 Lemon Squeezy variant IDs for new plan structure
# ✅ Verify variant IDs match products in Lemon Squeezy dashboard
# ✅ Test checkout flow for each plan type (monthly and annual)
# ✅ Verify webhook correctly identifies plan types from variant IDs
# ✅ Configure Moyasar webhook URL in dashboard (https://api.madna.me/api/webhooks/moyasar)
# ✅ Set MOYASAR_WEBHOOK_SECRET (matches dashboard webhook secret)
# ✅ Test webhook delivery using Moyasar dashboard test feature
# ✅ Enable payment.paid, payment.failed, and payment.refunded events in webhook settings
# ✅ Monitor webhook_logs table for processing errors
# ✅ Test payment form loads without errors in production environment
# ✅ Confirm only enabled payment methods are included in checkout
# ✅ Enable tokenization in Moyasar dashboard (for recurring billing)
# ✅ Configure persistent disk for UPLOADS_DIR
# ✅ Set correct BASE_URL and FRONTEND_URL
# ✅ Verify DATABASE_URL connection string
# ✅ AUTO_MIGRATE=true (enabled for automatic migrations)
# ✅ schema_migrations table created
# ✅ All pending migrations applied
# ========================================
# ----------------------------------------
# Resend Email Service Configuration
# ----------------------------------------
# Resend.com is used for transactional emails (receipts, notifications, contact forms)
# Sign up at https://resend.com and get API key from dashboard
# Documentation: https://resend.com/docs

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Production: re_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Development: re_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CRITICAL: Keep this secret! Used for sending emails via Resend API
# Find in Resend Dashboard → API Keys
# Free tier: 3,000 emails/month, 100 emails/day

RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Production: whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Used to verify webhook signatures from Resend
# Find in Resend Dashboard → Webhooks → (Select Webhook) → Signing Secret
# CRITICAL: Set this to enable email tracking and status updates


CONTACT_FORM_RECIPIENT_EMAIL=support@yourdomain.com
# Production: support@madna.me
# Email address that receives contact form submissions
# Can be a comma-separated list for multiple recipients
# Paid tier: 0/month for 50,000 emails

EMAIL_FROM=support@yourdomain.com
# Production: support@madna.me
# Development: dev@yourdomain.com
# MUST be a verified domain in Resend dashboard
# Format: email@domain.com or "Display Name <email@domain.com>"
# Domain verification required: Add DNS records (SPF, DKIM, DMARC)

EMAIL_REPLY_TO=support@yourdomain.com
# Optional: Reply-to address for customer responses
# Production: support@madna.me
# If not set, defaults to EMAIL_FROM
# Useful for routing replies to different inbox

# ========================================
# RESEND SETUP INSTRUCTIONS
# ========================================

# ----------------------------------------
# Messaging Configuration
# ----------------------------------------
ADMIN_NOTIFICATION_EMAIL=admin@yourdomain.com
# Email to receive notifications when businesses send inquiries
# Production: admin@madna.me

ADMIN_MESSAGE_RECIPIENT_EMAIL=admin@yourdomain.com
# Primary email for general admin message notifications (used if no specific admin assigned)
# Defaults to ADMIN_NOTIFICATION_EMAIL if not set

MESSAGE_NOTIFICATION_ENABLED=true
# Global toggle for messaging email notifications (default: true)
# Set to 'false' to disable all messaging notifications


ADMIN_FRONTEND_URL=https://admin.yourdomain.com
# URL for the admin dashboard (used in email links)
# Production: https://admin.madna.me
# Development: http://localhost:5173 or http://localhost:3000

# ========================================

# 1. Sign up at https://resend.com
# 2. Verify your domain:
#    - Navigate to Domains → Add Domain
#    - Add DNS records provided by Resend (SPF, DKIM, DMARC)
#    - Wait for verification (usually 5-10 minutes)
# 3. Create API key:
#    - Navigate to API Keys → Create API Key
#    - Copy key (starts with re_)
#    - Set RESEND_API_KEY environment variable
# 4. Test email sending:
#    - Use contact form or receipt email feature
#    - Check Resend dashboard for delivery status
# 5. Monitor usage:
#    - Free tier: 3,000 emails/month
#    - Check dashboard for usage metrics
#    - Upgrade to paid plan when needed
#
# Troubleshooting:
# - Issue: "Invalid API key"
#   Fix: Verify RESEND_API_KEY starts with re_ and matches dashboard
# - Issue: "Domain not verified"
#   Fix: Check DNS records in domain registrar, wait for propagation
# - Issue: "Email not delivered"
#   Fix: Check Resend dashboard logs, verify recipient email is valid
# - Issue: "Rate limit exceeded"
#   Fix: Upgrade plan or implement email queuing
#
# Webhook Configuration:
# 1. Add Endpoint in Resend Dashboard:
#    - URL: https://api.madna.me/api/webhooks/resend
#    - Development: https://your-ngrok-url.ngrok.io/api/webhooks/resend
# 2. Select Events:
#    - email.sent
#    - email.delivered
#    - email.bounced
#    - email.opened
#    - email.clicked
#    - email.clicked
#    - email.complained
# ========================================

# ----------------------------------------
# Email Service Configuration (Advanced)
# ----------------------------------------
RESEND_DAILY_LIMIT=100
# Maximum emails per day (Resend free tier limit)
# Free tier: 100 emails/day
# Paid tier: Adjust based on plan

EMAIL_RETRY_ENABLED=true
# Enable automatic retry of failed emails
# Set to 'false' to disable retry cron job

EMAIL_RETRY_MAX_ATTEMPTS=3
# Maximum retry attempts for failed emails
# Default: 3 (exponential backoff: 1s, 2s, 4s)

EMAIL_RETRY_INTERVAL_MINUTES=30
# Interval between retry batch processing
# Default: 30 minutes

EMAIL_ALERT_BOUNCE_THRESHOLD=5
# Bounce rate threshold for alerts (percentage)
# Default: 5% (industry standard)

EMAIL_ALERT_COMPLAINT_THRESHOLD=0.1
# Complaint rate threshold for alerts (percentage)
# Default: 0.1% (critical threshold)
