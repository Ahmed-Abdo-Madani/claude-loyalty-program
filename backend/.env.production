# Production Environment Configuration
# Backend API for madna.me loyalty platform

# Server Configuration
NODE_ENV=production
PORT=10000
BASE_URL=https://api.madna.me

# Frontend URL for CORS
FRONTEND_URL=https://app.madna.me

# Database Configuration (will be set via Render environment variables)
DATABASE_URL=${DATABASE_URL}

# Security Configuration
JWT_SECRET=${JWT_SECRET}
ENCRYPTION_KEY=${ENCRYPTION_KEY}
SESSION_SECRET=${SESSION_SECRET}

# Google Wallet Configuration
GOOGLE_SERVICE_ACCOUNT_EMAIL=${GOOGLE_SERVICE_ACCOUNT_EMAIL}
GOOGLE_PRIVATE_KEY=${GOOGLE_PRIVATE_KEY}
GOOGLE_PROJECT_ID=${GOOGLE_PROJECT_ID}

# Apple Wallet Configuration (if needed)
APPLE_PASS_TYPE_ID=${APPLE_PASS_TYPE_ID}
APPLE_TEAM_ID=${APPLE_TEAM_ID}
APPLE_PASS_CERTIFICATE=${APPLE_PASS_CERTIFICATE}
APPLE_PASS_CERTIFICATE_PASSWORD=${APPLE_PASS_CERTIFICATE_PASSWORD}

# Email Configuration (Resend)
# Legacy SENDGRID_API_KEY is deprecated and no longer used
RESEND_API_KEY=${RESEND_API_KEY}
EMAIL_FROM=noreply@madna.me
SUPPORT_EMAIL=customer_support@madna.me
ADMIN_EMAIL=super_admin@madna.me

# SMS Configuration (Future)
TWILIO_ACCOUNT_SID=${TWILIO_ACCOUNT_SID}
TWILIO_AUTH_TOKEN=${TWILIO_AUTH_TOKEN}

# Production Settings
DEMO_MODE=false
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security Headers
TRUST_PROXY=true