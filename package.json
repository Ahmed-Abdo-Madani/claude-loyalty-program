{
  "name": "loyalty-program-platform",
  "version": "1.0.0",
  "description": "A cost-effective and scalable loyalty program management platform for businesses",
  "type": "module",
  "scripts": {
    "dev": "set VITE_PORT=3000 && vite",
    "build": "vite build",
    "preview": "vite preview",
    "cap:assets": "npx @capacitor/assets generate",
    "cap:sync": "cap sync",
    "cap:build": "set CAPACITOR_BUILD=true&& vite build && cap sync",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "lint": "eslint src --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "backend": "cd backend && npm start",
    "backend:dev": "cd backend && npm run dev",
    "clean-ports": "node scripts/clean-ports.js",
    "dev:full": "npm run clean-ports && npx concurrently --kill-others-on-fail \"npm run backend\" \"npm run dev\"",
    "dev:windows": "start-dev.bat",
    "start": "concurrently \"npm run backend\" \"npm run preview\"",
    "start:clean": "npm run clean-ports && npm run start",
    "migrate:branch-manager": "node backend/migrations/20250127-add-branch-manager-auth.js",
    "migrate:pass-lifecycle": "node backend/migrations/20250127-add-pass-lifecycle-fields.js",
    "test:status-validation": "node backend/test/offer-status-validation.test.js && node backend/test/branch-status-validation.test.js && node backend/test/status-validation-integration.test.js",
    "test:offer-status": "node backend/test/offer-status-validation.test.js",
    "test:branch-status": "node backend/test/branch-status-validation.test.js",
    "test:status-integration": "node backend/test/status-validation-integration.test.js",
    "test:legacy-compat": "npx tsx backend/tests/legacy-data-compat.test.js"
  },
  "dependencies": {
    "@capacitor-mlkit/barcode-scanning": "^6.2.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/camera": "^6.1.3",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "axios": "^1.3.4",
    "barcode-detector": "^3.0.1",
    "browser-image-compression": "^2.0.2",
    "crypto-js": "^4.2.0",
    "date-fns": "^2.29.3",
    "i18next": "^23.7.0",
    "i18next-browser-languagedetector": "^7.2.0",
    "qrcode": "^1.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.4",
    "react-i18next": "^14.0.0",
    "react-icons": "^5.5.0",
    "react-pdf": "^10.3.0",
    "react-router-dom": "^6.8.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@vitejs/plugin-react": "^3.1.0",
    "autoprefixer": "^10.4.14",
    "concurrently": "^8.2.2",
    "eslint": "^8.35.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.3.4",
    "postcss": "^8.4.21",
    "tailwindcss": "^3.2.7",
    "typescript": "^5.9.3",
    "vite": "^4.1.0"
  }
}